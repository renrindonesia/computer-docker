# Copy to .env and adjust.
ADDR=:8080

# API key for ?key=... or X-API-Key header. Empty = auth disabled.
API_KEY=changeme

# Filesystem jail root. All fs paths are confined here.
FS_ROOT=/opt/data

# Exec timeouts (seconds).
EXEC_TIMEOUT_SEC=30
EXEC_MAX_TIMEOUT_SEC=300

# Audit log file (append-only JSON lines). Empty = in-memory ring only.
# Keep this OUTSIDE FS_ROOT so the sandbox can't read/tamper with it.
AUDIT_LOG=/opt/audit.log
