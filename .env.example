# Copy to .env and adjust.
ADDR=:8080

# API key for ?key=... or X-API-Key header. Empty = auth disabled.
API_KEY=changeme

# Filesystem jail root. All fs paths are confined here.
FS_ROOT=/opt/data

# Exec timeouts (seconds).
EXEC_TIMEOUT_SEC=30
EXEC_MAX_TIMEOUT_SEC=300

# Audit log file (append-only JSON lines). Empty = in-memory ring only.
# Keep this OUTSIDE FS_ROOT so the sandbox can't read/tamper with it.
AUDIT_LOG=/opt/audit.log

# Live desktop (noVNC) reverse-proxied under /vnc/. Empty = disabled.
VNC_UPSTREAM=http://127.0.0.1:6080

# Who may embed the viewer in an <iframe>. Becomes the CSP frame-ancestors
# directive. "*" = any site; or a space-separated origin allow list.
VNC_FRAME_ANCESTORS=*

# Password for the VNC session. UNSET = desktop is unauthenticated (public!).
# Set this in production since /vnc/ is not behind the API key.
VNC_PASSWORD=

# Virtual screen geometry for Xvfb.
SCREEN_GEOMETRY=1280x800x24
